            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Build Json" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput
import java.util.Random

def random = new Random()

// Read existing ordered items (must include orderedItemId)
def existingJson = vars.get(&quot;allOrderedItems&quot;)
def itemsList = []

if (existingJson &amp;&amp; existingJson.trim() != &quot;&quot;) {
    itemsList = new JsonSlurper().parseText(existingJson)

    // ✅ Map backend &quot;id&quot; to &quot;orderedItemId&quot; for PUT request
    itemsList.each { item -&gt;
        if (item.containsKey(&quot;id&quot;) &amp;&amp; !item.containsKey(&quot;orderedItemId&quot;)) {
            item.orderedItemId = item.id
        }
    }
}

// Select new available item
def total = vars.get(&quot;item_id_matchNr&quot;) as int
def availableIds = []

for (int i = 1; i &lt;= total; i++) {
    if (vars.get(&quot;is_available_&quot; + i) == &quot;true&quot;) {
        availableIds.add(vars.get(&quot;item_id_&quot; + i))
    }
}

if (!availableIds.isEmpty()) {

    def selectedId = availableIds[random.nextInt(availableIds.size())]

    def newItem = [
            itemId: selectedId,
            quantity: random.nextInt(5) + 1,
            notes: &quot;Do not use nuts as I&apos;m allergic&quot;,
            orderedItemModifiers: []
            // DO NOT add orderedItemId here
    ]

    itemsList.add(newItem)
}

// Save full updated structure
vars.put(&quot;allOrderedItems&quot;, JsonOutput.toJson(itemsList))

log.info(&quot;Final update payload: &quot; + JsonOutput.toJson(itemsList))
</stringProp>
            </JSR223PostProcessor>
