            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">def total = vars.get(&quot;category_id_matchNr&quot;) as int

// Get loop index safely
def index = vars.getIteration() - 1

// Safety check
if (index &lt; total) {
    def categoryId = vars.get(&quot;category_id_&quot; + (index + 1))
    vars.put(&quot;currentCategoryId&quot;, categoryId)
    log.info(&quot;Using categoryId: &quot; + categoryId)
} else {
    log.warn(&quot;Index exceeded category count&quot;)
}
</stringProp>
          </JSR223PreProcessor>
