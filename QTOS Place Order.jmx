            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Build JSon For Place Order">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput
import java.util.Random

def random = new Random()

// ✅ 1️⃣ Get selected itemId from PreProcessor
def itemId = vars.get(&quot;currentItemId&quot;)

if (!itemId || itemId.trim() == &quot;&quot;) {
    log.error(&quot;currentItemId is null while building order JSON&quot;)
    return
}

// ✅ 2️⃣ Check modifier flag
def hasModifier = vars.get(&quot;has_modifier&quot;)

def orderedModifiers = []

// ✅ 3️⃣ If item has modifiers
if (hasModifier == &quot;true&quot;) {

    def json = vars.get(&quot;modifierDetailsJson&quot;)

    if (json &amp;&amp; json != &quot;null&quot; &amp;&amp; json.trim() != &quot;&quot;) {

        def modifierDetails = new JsonSlurper().parseText(json)

        modifierDetails.each { group -&gt;

            def groupId = group.modifierGroup.id
            def allowMulti = group.modifierGroup.allowMultiSelect
            def min = group.modifierGroup.minLimit ?: 1
            def max = group.modifierGroup.maxLimit ?: 1
            def items = group.modifierItems

            if (items &amp;&amp; items.size() &gt; 0) {

                if (!allowMulti) {
                    // ✅ Single select
                    def selected = items[random.nextInt(items.size())]

                    orderedModifiers.add([
                            modifierGroupId: groupId,
                            modifierItemIds: [selected.id]
                    ])

                } else {
                    // ✅ Multi select

                    if (max &gt; items.size()) {
                        max = items.size()
                    }

                    if (min &gt; max) {
                        min = max
                    }

                    def count = random.nextInt((max - min) + 1) + min

                    def shuffled = items.sort { Math.random() }
                    def selectedItems = shuffled.take(count).collect { it.id }

                    orderedModifiers.add([
                            modifierGroupId: groupId,
                            modifierItemIds: selectedItems
                    ])
                }
            }
        }
    }
}

// ✅ 4️⃣ Build item object
def itemObject = [
        itemId: itemId,
        quantity: random.nextInt(5) + 1,
        notes: &quot;Do not use nuts as I&apos;m allergic&quot;,
        orderedItemModifiers: orderedModifiers
]

// ✅ 5️⃣ Retrieve existing ordered items list
def existingItemsJson = vars.get(&quot;allOrderedItems&quot;)

def itemsList = []

if (existingItemsJson &amp;&amp; existingItemsJson.trim() != &quot;&quot;) {
    itemsList = new JsonSlurper().parseText(existingItemsJson)
}

// ✅ 6️⃣ Add current item
itemsList.add(itemObject)

// ✅ 7️⃣ Save updated list
vars.put(&quot;allOrderedItems&quot;, JsonOutput.toJson(itemsList))

log.info(&quot;Updated orderedItems: &quot; + JsonOutput.toJson(itemsList))
</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">def total = vars.get(&quot;item_id_matchNr&quot;) as int

if (total == 0) {
    log.error(&quot;No items found!&quot;)
    return
}

def availableIds = []

for (int i = 1; i &lt;= total; i++) {
    if (vars.get(&quot;is_available_&quot; + i) == &quot;true&quot;) {
        availableIds.add(vars.get(&quot;item_id_&quot; + i))
    }
}

if (availableIds.isEmpty()) {
    log.error(&quot;No available items!&quot;)
    return
}

def randomIndex = new Random().nextInt(availableIds.size())
def selectedId = availableIds[randomIndex]

vars.put(&quot;currentItemId&quot;, selectedId)

log.info(&quot;PreProcessor selected currentItemId: &quot; + selectedId)
</stringProp>
            </JSR223PreProcessor>
