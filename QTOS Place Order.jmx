          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract Random Item ID With Availability Flag = true" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">def total = vars.get(&quot;item_id_matchNr&quot;) as int

if (!total || total == 0) {
    vars.put(&quot;loopCount&quot;, &quot;1&quot;)
    return
}

// Random between 1 and total items
def randomLoops = new Random().nextInt(total) + 1

vars.put(&quot;loopCount&quot;, randomLoops.toString())

log.info(&quot;Loop count set to: &quot; + randomLoops)
</stringProp>
