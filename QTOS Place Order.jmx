          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">def totalStr = vars.get(&quot;item_id_matchNr&quot;)

if (!totalStr || totalStr == &quot;0&quot;) {
    log.error(&quot;No items found!&quot;)
    return
}

def total = totalStr as int
def availableIds = []

for (int i = 1; i &lt;= total; i++) {

    def id = vars.get(&quot;item_id_&quot; + i)
    def available = vars.get(&quot;is_available_&quot; + i)

    if (id &amp;&amp; available == &quot;true&quot;) {
        availableIds.add(id)
    }
}

if (availableIds.isEmpty()) {
    log.error(&quot;No AVAILABLE items found!&quot;)
    return
}

def randomIndex = new Random().nextInt(availableIds.size())
def selectedId = availableIds[randomIndex]

vars.put(&quot;currentItemId&quot;, selectedId)

log.info(&quot;Selected AVAILABLE currentItemId: &quot; + selectedId)
</stringProp>
