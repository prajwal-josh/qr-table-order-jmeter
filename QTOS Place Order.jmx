          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Json Array For PUSH items to KDS">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput

try {

    def response = prev.getResponseDataAsString()
    def json = new JsonSlurper().parseText(response)

    def items = json.data.order.orderedItems

   def notServedItemIds =[];
    def servedItemsIds = []

    items.each { item -&gt;

        if(item.itemStatus == &quot;SERVED&quot;){
            servedItems.add(item.id);
        }else {
		notServedItemIds.add(item.id);
		}

    }

    vars.put(&quot;nonServedItemArray&quot;, JsonOutput.toJson(notServedItemIds))
   
    vars.put(&quot;servedItemArray&quot;, JsonOutput.toJson(servedItems))

    log.info(&quot;nonServed  items: &quot; + vars.get(&quot;nonServedItemArray&quot;))
    log.info(&quot;SERVED items: &quot; + vars.get(&quot;servedItemArray&quot;))

} catch (Exception e) {
    log.error(&quot;Error building item status arrays&quot;, e)
}</stringProp>
          </JSR223PostProcessor>
